// Baja 411 — Month 1 Schema
// Run migrations once DATABASE_URL is set in .env

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth) ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  mapPins       MapPin[]
  businesses    Business[]
  classifieds   Classified[]
  events        Event[]
  reviews       Review[]
  reports       Report[]
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

// ─── Map Pins ─────────────────────────────────────────────────────────────────

model MapPin {
  id          String      @id @default(cuid())
  title       String
  description String?
  lat         Float
  lng         Float
  category    PinCategory
  photos      String[]
  status      PinStatus   @default(PENDING)
  authorId    String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  author      User        @relation(fields: [authorId], references: [id])
  reviews     Review[]
  reports     Report[]
}

enum PinCategory {
  BOONDOCKING
  BEACH
  WATER_FILL
  DUMP_STATION
  MECHANIC
  FUEL
  TRAILHEAD
  FISHING
  MARKET
  OTHER
}

enum PinStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Business Directory ───────────────────────────────────────────────────────

model Business {
  id          String           @id @default(cuid())
  name        String
  category    BusinessCategory
  town        Town
  address     String?
  phone       String?
  website     String?
  description String?
  photos      String[]
  lat         Float?
  lng         Float?
  status      PinStatus        @default(PENDING)
  authorId    String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  lastVerified DateTime?

  author      User             @relation(fields: [authorId], references: [id])
  reviews     Review[]
  reports     Report[]
}

enum BusinessCategory {
  RESTAURANT
  BAR
  BAKERY
  BREWERY
  HOTEL
  RENTAL
  MECHANIC
  TIRE_SHOP
  FUEL
  MEDICAL
  DENTAL
  PHARMACY
  GROCERY
  OTHER
}

enum Town {
  CERRITOS
  PESCADERO
  TODOS_SANTOS
  LA_PAZ
  CABO_SAN_LUCAS
  SAN_JOSE_DEL_CABO
  LORETO
  OTHER
}

// ─── Classifieds ──────────────────────────────────────────────────────────────

model Classified {
  id          String             @id @default(cuid())
  title       String
  description String
  price       Float?
  category    ClassifiedCategory
  photos      String[]
  location    String?
  lat         Float?
  lng         Float?
  status      ClassifiedStatus   @default(ACTIVE)
  authorId    String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  expiresAt   DateTime

  author      User               @relation(fields: [authorId], references: [id])
  reports     Report[]
}

enum ClassifiedCategory {
  VEHICLE
  BOAT
  GEAR
  HOUSING
  SERVICE
  FREE
  OTHER
}

enum ClassifiedStatus {
  ACTIVE
  SOLD
  EXPIRED
  REMOVED
}

// ─── Events Calendar ──────────────────────────────────────────────────────────

model Event {
  id          String        @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  location    String?
  town        Town?
  category    EventCategory
  url         String?
  status      PinStatus     @default(PENDING)
  authorId    String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  author      User          @relation(fields: [authorId], references: [id])
}

enum EventCategory {
  FESTIVAL
  MARKET
  ART
  MUSIC
  FOOD
  SPORTS
  GOVERNMENT
  COMMUNITY
  OTHER
}

// ─── Blog ─────────────────────────────────────────────────────────────────────

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String?
  content     String
  coverImage  String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Reviews ─────────────────────────────────────────────────────────────────

model Review {
  id         String    @id @default(cuid())
  rating     Int
  comment    String?
  authorId   String
  pinId      String?
  businessId String?
  createdAt  DateTime  @default(now())

  author     User      @relation(fields: [authorId], references: [id])
  pin        MapPin?   @relation(fields: [pinId], references: [id])
  business   Business? @relation(fields: [businessId], references: [id])
}

// ─── Reports ─────────────────────────────────────────────────────────────────

model Report {
  id           String        @id @default(cuid())
  reason       String
  authorId     String
  pinId        String?
  businessId   String?
  classifiedId String?
  resolved     Boolean       @default(false)
  createdAt    DateTime      @default(now())

  author       User          @relation(fields: [authorId], references: [id])
  pin          MapPin?       @relation(fields: [pinId], references: [id])
  business     Business?     @relation(fields: [businessId], references: [id])
  classified   Classified?   @relation(fields: [classifiedId], references: [id])
}
